{
  "name": "website-intelligence-backend",
  "version": "1.0.0",
  "description": "Production-grade AI orchestration backend for website intelligence SaaS.",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:api": "tsx watch src/server.ts",
    "dev:worker:analysis": "tsx watch src/workers/analysis.worker.ts",
    "dev:worker:trend": "tsx watch src/workers/trend.worker.ts",
    "dev:worker:roadmap": "tsx watch src/workers/roadmap.worker.ts",
    "dev:worker:planning": "tsx watch src/workers/planning.worker.ts",
    "dev:workers": "concurrently --kill-others-on-fail --names analysis,trend,roadmap,planning --prefix-colors green,magenta,cyan,yellow \"npm:dev:worker:analysis\" \"npm:dev:worker:trend\" \"npm:dev:worker:roadmap\" \"npm:dev:worker:planning\"",
    "dev:full": "tsx watch src/dev/full.ts",
    "dev:full:multi": "concurrently --kill-others-on-fail --names api,analysis,trend,roadmap,planning --prefix-colors blue,green,magenta,cyan,yellow \"npm:dev:api\" \"npm:dev:worker:analysis\" \"npm:dev:worker:trend\" \"npm:dev:worker:roadmap\" \"npm:dev:worker:planning\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "start:worker:analysis": "node dist/workers/analysis.worker.js",
    "start:worker:trend": "node dist/workers/trend.worker.js",
    "start:worker:roadmap": "node dist/workers/roadmap.worker.js",
    "start:worker:planning": "node dist/workers/planning.worker.js",
    "start:workers": "concurrently --kill-others-on-fail --names analysis,trend,roadmap,planning --prefix-colors green,magenta,cyan,yellow \"npm:start:worker:analysis\" \"npm:start:worker:trend\" \"npm:start:worker:roadmap\" \"npm:start:worker:planning\"",
    "start:full": "concurrently --kill-others-on-fail --names api,analysis,trend,roadmap,planning --prefix-colors blue,green,magenta,cyan,yellow \"npm:start\" \"npm:start:worker:analysis\" \"npm:start:worker:trend\" \"npm:start:worker:roadmap\" \"npm:start:worker:planning\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:bootstrap": "tsx src/scripts/db-bootstrap.ts",
    "db:prepare": "npm run prisma:generate && npm run prisma:deploy && npm run db:bootstrap",
    "export:manager-dataset": "tsx src/scripts/export-manager-training-data.ts",
    "export:manager-dpo-dataset": "tsx src/scripts/export-manager-preference-data.ts",
    "export:forecast-dataset": "tsx src/scripts/export-forecast-training-data.ts",
    "gate:helena-rollout": "tsx src/scripts/evaluate-helena-rollout-gate.ts",
    "smoke:analyze": "tsx src/scripts/smoke-analyze.ts",
    "worker:analysis": "tsx src/workers/analysis.worker.ts",
    "worker:trend": "tsx src/workers/trend.worker.ts",
    "worker:roadmap": "tsx src/workers/roadmap.worker.ts",
    "worker:planning": "tsx src/workers/planning.worker.ts",
    "worker:all": "concurrently \"npm:worker:analysis\" \"npm:worker:trend\" \"npm:worker:roadmap\" \"npm:worker:planning\"",
    "test:loop1": "tsx src/scripts/test-opportunity-assess.ts",
    "test:loop2": "tsx src/scripts/test-client-acquisition-assess.ts",
    "test:loop2-loop3": "tsx src/scripts/test-loop2-loop3-endpoints.ts",
    "test:idea-stream": "tsx src/scripts/test-idea-stream.ts",
    "test:manager-chat": "tsx src/scripts/test-manager-chat-stream.ts",
    "test:health-summary": "tsx src/scripts/test-health-summary-auto-actions.ts",
    "test:briefing-insights": "tsx src/scripts/test-briefing-insights.ts",
    "test:sprint4-workers": "tsx src/scripts/test-sprint4-workers.ts",
    "test:data-quality": "tsx src/scripts/test-data-quality-checkpoint.ts",
    "test:core-context": "tsx src/scripts/test-core-context.ts",
    "security:audit": "npm audit --omit=dev"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.3.1",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-errors": "^2.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.13.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.3.1",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "effect": "^3.20.0"
  }
}
